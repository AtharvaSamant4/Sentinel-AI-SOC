# ─── SENTINEL AI-SOC · Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Google Gemini (AI Analyst) ────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── AbuseIPDB (IP Reputation) ────────────────────────────────────────────────
# Get your key at: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── Twilio (SMS Alerts) ───────────────────────────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_SID=your_twilio_account_sid_here
TWILIO_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=+1xxxxxxxxxx

# ── Admin Contact ────────────────────────────────────────────────────────────
ADMIN_PHONE=+1xxxxxxxxxx

# ── Event Stream Tuning (optional) ───────────────────────────────────────────
SENTINEL_TARGET_EPS=0.4
SENTINEL_EVENT_MIN_INTERVAL_SECONDS=2.0
SENTINEL_EVENT_MAX_INTERVAL_SECONDS=3.0
